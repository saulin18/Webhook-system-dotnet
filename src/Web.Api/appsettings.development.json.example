{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=clean-architecture;Username=postgres;Password=YOUR_PASSWORD;Include Error Detail=true"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "clean-architecture",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "Webhooks": {
    "MaxRetries": 3,
    "TimeoutSeconds": 30,
    "RetryDelaySeconds": [60, 300, 900]
  }
}